{
  "manifest_version": 3,
  "name": "ChatGPT Pop-up",
  "version": "1.0",
  "description": "Popup on chatgpt.com with a question and two options.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "scripts": ["background.js"],
  },
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
